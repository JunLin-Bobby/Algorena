# Copy to .env and adjust values as needed.
# cp .env.example .env

# SQLite database (default: backend/algorena.db)
# DATABASE_URL=sqlite+aiosqlite:///C:/path/to/algorena.db

# Claude API — required for real AI judging; omit to use mock judge in dev
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514


# JSON array; omit to use defaults in config.py
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
