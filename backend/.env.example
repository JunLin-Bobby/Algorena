# Copy to .env and adjust values as needed.
# cp .env.example .env

# ─── Database ───────────────────────────────────────────
# Omit DATABASE_URL to use default backend/algorena.db
DATABASE_URL=sqlite+aiosqlite:///./algorena.db

# ─── AI judge (LLMJudgeService) ─────────────────────────
# Leave OPENAI_API_KEY empty to use MockJudgeService in local dev .
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=1024

# ─── Game rules (injected into Room via main.py) ─────────
GAME_DURATION_SECONDS=300
MAX_PLAYERS=2
VIOLATION_PENALTY=5

# ─── CORS (JSON array) ───────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
